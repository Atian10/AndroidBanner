<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:paddingLeft="@dimen/banner_card_padding"
    android:paddingRight="@dimen/banner_card_padding">

    <ImageView
        android:id="@+id/iv_banner_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/banner_image_desc"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tv_banner_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="@dimen/banner_title_padding"
        android:textColor="@color/banner_title_text"
        android:textSize="@dimen/banner_text_size_title"
        android:layout_gravity="bottom"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
